#include <iostream>
#include <vector>
using namespace std;

string fairRations(vector<int> B) {
    int loaves = 0;
    int n = B.size();

    for (int i = 0; i < n - 1; ++i) {
        if (B[i] % 2 != 0) {
            B[i]++;
            B[i + 1]++;
            loaves += 2;
        }
    }

    // Check if all are even
    for (int i = 0; i < n; ++i) {
        if (B[i] % 2 != 0)
            return "NO";
    }

    return to_string(loaves);
}

int main() {
    int n;
    cin >> n;
    vector<int> B(n);
    for (int i = 0; i < n; ++i) {
        cin >> B[i];
    }

    cout << fairRations(B) << endl;
    return 0;
}
