#include <bits/stdc++.h>

using namespace std;

int sansaXor (vector<int>arr)
{
  int n=arr.size();
   int answer=0;
   if (n%2==0)
     {
       return 0;
     }
  for (int i=0;i<n;i+=2)
  {
   
     
       answer=answer^arr[i];
     
  }
  return answer;
 
}
int main()
{
  int t;
  cin>>t;

   while (t--)
   { 
     int n;
     cin>>n;
     int x;
     vector<int>arr;
     for (int i=0;i<n;i++)
     {
       cin>>x;
       arr.push_back(x);
     }
      cout<<sansaXor(arr)<<endl;
   }
    return 0;
}
